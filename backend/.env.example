# Configuracion del backend del simulador.
# Copiar a `.env` y editar valores antes de `docker compose up`.
#
# IMPORTANTE: en produccion, regenerar todos los secrets con:
#   openssl rand -hex 32

# ====================================================================
# Modo de despliegue
# ====================================================================
# Local (HTTP, sin certificados):
#   DOMAIN=localhost
#   SCHEME=http://
#   PORT=8080
#
# Produccion (HTTPS automatico via Let's Encrypt):
#   DOMAIN=api.tu-dominio.com
#   SCHEME=             (vacio — Caddy detecta y usa HTTPS automaticamente)
#   PORT=443
#   HTTPS_PORT=443
DOMAIN=localhost
SCHEME=http://
PORT=8080
HTTPS_PORT=443

PUBLIC_BASE_URL=http://localhost:8080

# ====================================================================
# Postgres
# ====================================================================
POSTGRES_USER=simulador
POSTGRES_PASSWORD=changeme
POSTGRES_DB=simulador

# ====================================================================
# MinIO (bucket S3-compatible)
# ====================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_BUCKET=simulador-updates

# ====================================================================
# Auth
# ====================================================================
# Cambiar JWT_SECRET en produccion. Generar: openssl rand -hex 32
JWT_SECRET=dev-jwt-secret-change-me-in-production
ADMIN_DEFAULT_USER=admin
ADMIN_DEFAULT_PASS=admin123

# API key que usa GitHub Actions para subir versiones (Sprint 11).
API_KEY_CI=dev-ci-key-change-me

# ====================================================================
# Logging
# ====================================================================
LOG_LEVEL=info
